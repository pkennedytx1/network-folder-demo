    <script>
        // Page Navigation
        function showNetworkOverview() {
            document.getElementById('network-overview-page').style.display = 'block';
            document.getElementById('main-container').style.display = 'none';
            document.getElementById('data-standard-nav').style.display = 'none';
            document.getElementById('participant-detail-page').style.display = 'none';
            document.getElementById('incident-detail-page').style.display = 'none';
            window.scrollTo(0, 0);
        }

        function showDataStandard(type) {
            if (type === 'participant-incident') {
                document.getElementById('network-overview-page').style.display = 'none';
                document.getElementById('main-container').style.display = 'block';
                document.getElementById('data-standard-nav').style.display = 'block';
                document.getElementById('participant-detail-page').style.display = 'none';
                document.getElementById('incident-detail-page').style.display = 'none';
                // Show participants tab by default
                showTab('participants');
                window.scrollTo(0, 0);
            }
        }

        // Sync time tracking functions
        let lastSyncTimestamp = Date.now();

        function updateSyncTime() {
            // Updates the "Last synced X minutes ago" display
            const syncElements = document.querySelectorAll('.sync-time');
            if (syncElements.length === 0) return;

            const now = Date.now();
            const diff = Math.floor((now - lastSyncTimestamp) / 1000);

            let timeStr;
            if (diff < 60) {
                timeStr = 'just now';
            } else if (diff < 3600) {
                const mins = Math.floor(diff / 60);
                timeStr = `${mins} ${mins === 1 ? 'minute' : 'minutes'} ago`;
            } else {
                const hours = Math.floor(diff / 3600);
                timeStr = `${hours} ${hours === 1 ? 'hour' : 'hours'} ago`;
            }

            syncElements.forEach(el => {
                el.textContent = timeStr;
            });
        }

        function startSyncSimulation() {
            // Update sync time display every minute
            setInterval(updateSyncTime, 60000);
        }

        // Tab switching within data standard
        function showTab(tabName) {
            // Update tab buttons
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));

            // Activate selected tab
            const tabButton = document.querySelector(`.tab[data-tab="${tabName}"]`);
            const tabContent = document.getElementById(`${tabName}-tab`);

            if (tabButton) tabButton.classList.add('active');
            if (tabContent) tabContent.classList.add('active');
        }

        // Initialize tab click handlers
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.tab').forEach(tab => {
                tab.addEventListener('click', () => {
                    showTab(tab.dataset.tab);
                });
            });

            // Show overview page by default
            showNetworkOverview();

            // Initialize sync timestamp (set to 2 minutes ago for demo)
            lastSyncTimestamp = Date.now() - 120000;
            updateSyncTime();

            // Start sync simulation (for demo)
            startSyncSimulation();

            // Initialize all mention-enabled textareas
            document.querySelectorAll('.mention-enabled').forEach(textarea => {
                initializeMentionAutocomplete(textarea);
            });
        });

        // Collapsible sections
        function toggleSection(header) {
            header.parentElement.classList.toggle('expanded');
        }

        // Toggle org table
        function toggleOrgTable() {
            // Check which page is visible
            const overviewPage = document.getElementById('network-overview-page');
            const dataStandardPage = document.getElementById('main-container');

            if (overviewPage.style.display !== 'none') {
                // We're on the overview page
                const section = document.getElementById('org-section-overview');
                section.style.display = section.style.display === 'none' ? 'block' : 'none';
            } else if (dataStandardPage.style.display !== 'none') {
                // We're on the data standard page
                const section = document.getElementById('org-section');
                section.style.display = section.style.display === 'none' ? 'block' : 'none';
            }
        }

        // PII toggle
        let piiHidden = true;
        function togglePII() {
            piiHidden = !piiHidden;

            // Update main page PII toggle
            const mainPiiIcon = document.getElementById('pii-icon');
            const mainPiiText = document.getElementById('pii-text');
            if (mainPiiIcon) {
                mainPiiIcon.innerHTML = piiHidden ? '<i class="fas fa-lock"></i>' : '<i class="fas fa-eye"></i>';
                mainPiiText.textContent = piiHidden ? 'PII Hidden' : 'PII Visible';
            }

            // Update detail page PII toggle
            const detailPiiIcon = document.getElementById('detail-pii-icon');
            const detailPiiText = document.getElementById('detail-pii-text');
            if (detailPiiIcon) {
                detailPiiIcon.innerHTML = piiHidden ? '<i class="fas fa-lock"></i>' : '<i class="fas fa-eye"></i>';
                detailPiiText.textContent = piiHidden ? 'PII Hidden' : 'PII Visible';
            }

            // Toggle all PII fields
            document.querySelectorAll('.pii-field').forEach(field => {
                const masked = field.querySelector('.pii-masked');
                const revealed = field.querySelector('.pii-revealed');
                if (masked && revealed) {
                    masked.style.display = piiHidden ? 'inline' : 'none';
                    revealed.style.display = piiHidden ? 'none' : 'inline';
                }
            });
        }

        // View mode toggle (Lead vs Member)
        let isLeadView = true;
        function toggleViewMode() {
            isLeadView = !isLeadView;

            // Update the shared demo control button
            const viewIcon = document.getElementById('view-icon');
            const viewText = document.getElementById('view-text');

            if (viewIcon && viewText) {
                if (isLeadView) {
                    viewIcon.className = 'fas fa-crown';
                    viewText.textContent = 'Lead View';
                } else {
                    viewIcon.className = 'fas fa-user';
                    viewText.textContent = 'Member View';
                }
            }

            // Update UI based on view mode
            updateUIForViewMode();
        }

        // Member type toggle (Internal vs External)
        let isInternalMember = true;
        function toggleMemberType() {
            isInternalMember = !isInternalMember;

            // Update button text on both pages
            const memberTypeText = document.getElementById('member-type-text');
            const memberTypeText2 = document.getElementById('member-type-text-2');

            const newText = isInternalMember ? 'Internal Member' : 'External Member';

            if (memberTypeText) memberTypeText.textContent = newText;
            if (memberTypeText2) memberTypeText2.textContent = newText;

            // Update UI based on member type
            updateUIForViewMode();
        }

        // Update UI elements based on current view mode
        function updateUIForViewMode() {
            // This function will control what UI elements are visible/enabled
            // based on whether user is viewing as Lead, Internal Member, or External Member

            if (isLeadView) {
                // Lead view: can see everything, manage network settings
                console.log('Lead View: Full access');
            } else if (isInternalMember) {
                // Internal Member: network member with data standard implemented
                console.log('Internal Member View: Can contribute and see shared data');
            } else {
                // External Member: network member without data standard implemented
                console.log('External Member View: Limited visibility, cannot contribute');
            }

            // TODO: Add specific UI changes based on view mode
            // Examples:
            // - Hide/show "Create" buttons
            // - Disable match confirmation for external members
            // - Hide PII for external members
            // - Show/hide organization settings
        }

        // Real-time connection status (via GraphQL subscriptions)
        // In the real app, this would monitor WebSocket connection state
        // For demo: status dot pulses continuously to show "connected" state
        function initializeConnectionStatus() {
            const statusDots = document.querySelectorAll('.status-dot');

            // Pulse animation every 2 seconds to show active connection
            setInterval(() => {
                statusDots.forEach(dot => {
                    dot.classList.add('pulse');
                    setTimeout(() => {
                        dot.classList.remove('pulse');
                    }, 1500);
                });
            }, 2000);
        }

        // Initialize on page load
        initializeConnectionStatus();

