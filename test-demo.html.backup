                            </div>
                            <div class="consensus-option-content">
                                <div class="consensus-option-value">145 Oak Street, Austin, TX 78744</div>
                                <div class="consensus-option-meta">
                                    <div class="consensus-org-badges">
                                        <div class="consensus-org-badge">LO</div>
                                        <div class="consensus-org-badge">PA</div>
                                        <div class="consensus-org-badge">SS</div>
                                    </div>
                                    <div class="consensus-vote-count">
                                        <i class="fas fa-check-circle"></i>
                                        3 orgs
                                    </div>
                                    <div class="consensus-majority-badge">
                                        <i class="fas fa-star"></i>
                                        Majority
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Option 2: Alternative -->
                        <div class="consensus-option"
                             data-field="address"
                             data-value="145 Oak St, Austin, TX 78744"
                             onclick="selectConsensusOption('address', '145 Oak St, Austin, TX 78744')">
                            <div class="consensus-radio">
                                <div class="consensus-radio-inner"></div>
                            </div>
                            <div class="consensus-option-content">
                                <div class="consensus-option-value">145 Oak St, Austin, TX 78744</div>
                                <div class="consensus-option-meta">
                                    <div class="consensus-org-badges">
                                        <div class="consensus-org-badge">TC</div>
                                        <div class="consensus-org-badge">YS</div>
                                    </div>
                                    <div class="consensus-vote-count">
                                        <i class="fas fa-check-circle"></i>
                                        2 orgs
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Stats Summary -->
                <div class="consensus-stats">
                    <div class="consensus-stat">
                        <i class="fas fa-building"></i>
                        <span><strong>5</strong> organizations with records</span>
                    </div>
                    <div class="consensus-stat">
                        <i class="fas fa-exchange-alt"></i>
                        <span><strong>4</strong> fields with conflicts</span>
                    </div>
                    <div class="consensus-stat">
                        <i class="fas fa-star"></i>
                        <span><strong>4</strong> majority values auto-selected</span>
                    </div>
                    <div class="consensus-stat">
                        <i class="fas fa-sync-alt"></i>
                        <span><strong>2</strong> orgs will need to sync</span>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <div style="font-size: 13px; color: var(--gray-600);">
                    <i class="fas fa-info-circle" style="margin-right: 4px;"></i>
                    Each organization will need to manually sync their records to match the consensus
                </div>
                <div style="display: flex; gap: 8px;">
                    <button class="btn" onclick="closeConsensusBuilder()">Cancel</button>
                    <button class="btn btn-primary" onclick="saveConsensusChanges()">
                        <i class="fas fa-check-double"></i> Establish Consensus
                    </button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
