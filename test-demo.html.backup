        // @ Mention Autocomplete Functionality
        const mentionData = [
            // Participants
            { type: 'participant', id: 'P-1042', name: 'DeShawn Williams', meta: 'Victim', icon: 'fa-user' },
            { type: 'participant', id: 'P-1089', name: 'Marcus Johnson', meta: 'Witness', icon: 'fa-user' },
            { type: 'participant', id: 'P-1124', name: 'Tyrone Robinson', meta: 'At Risk', icon: 'fa-user' },
            { type: 'participant', id: 'P-2156', name: 'Deandre Williams', meta: 'Participant', icon: 'fa-user' },
            { type: 'participant', id: 'P-3091', name: 'Marcus Thompson', meta: 'Participant', icon: 'fa-user' },
            { type: 'participant', id: 'P-1024', name: 'Jamal Davis', meta: 'Participant', icon: 'fa-user' },
            { type: 'participant', id: 'P-1056', name: 'Keisha Brown', meta: 'Participant', icon: 'fa-user' },
            // Incidents
            { type: 'incident', id: 'INC-0091', name: 'Shooting - E. William Cannon Dr.', meta: 'Critical', icon: 'fa-exclamation-triangle' },
            { type: 'incident', id: 'INC-432', name: 'Assault - Manor Rd', meta: 'High', icon: 'fa-exclamation-triangle' },
            { type: 'incident', id: 'INC-401', name: 'Threats - Riverside Dr', meta: 'Medium', icon: 'fa-exclamation-triangle' },
            // Organizations
            { type: 'org', id: 'peacemakers', name: 'Peacemakers Austin', meta: 'Member Organization', icon: 'fa-building' },
            { type: 'org', id: 'trauma-care', name: 'Trauma-Informed Care', meta: 'Member Organization', icon: 'fa-building' },
            { type: 'org', id: 'street-outreach', name: 'Street Outreach Team', meta: 'Member Organization', icon: 'fa-building' },
            { type: 'org', id: 'youth-services', name: 'Youth Services', meta: 'Member Organization', icon: 'fa-building' },
            { type: 'org', id: 'safe-streets', name: 'Safe Streets East Austin', meta: 'Member Organization', icon: 'fa-building' },
            { type: 'org', id: 'vpc', name: 'Violence Prevention Coalition', meta: 'Member Organization', icon: 'fa-building' }
        ];

        // Initialize mention functionality for each textarea
        function initializeMentionAutocomplete(textarea) {
            if (!textarea) return;

            const textareaId = textarea.id;
            const autocompleteId = textareaId.replace('note-textarea', 'mention-autocomplete');
            const autocomplete = document.getElementById(autocompleteId);
            const listContainer = autocomplete ? autocomplete.querySelector('.mention-list-content') : null;

            if (!autocomplete || !listContainer) return;

            let mentionStartPos = -1;
            let mentionQuery = '';
            let selectedMentionIndex = 0;

            textarea.addEventListener('input', function(e) {
                const text = this.value;
                const cursorPos = this.selectionStart;

                // Find the last @ symbol before cursor
                const textBeforeCursor = text.substring(0, cursorPos);
                const lastAtIndex = textBeforeCursor.lastIndexOf('@');

                if (lastAtIndex !== -1) {
                    // Check if there's a space between @ and cursor
                    const textAfterAt = textBeforeCursor.substring(lastAtIndex + 1);
                    if (!textAfterAt.includes(' ') && !textAfterAt.includes('\n')) {
                        mentionStartPos = lastAtIndex;
                        mentionQuery = textAfterAt.toLowerCase();
                        showMentionAutocomplete();
                    } else {
                        hideMentionAutocomplete();
                    }
                } else {
                    hideMentionAutocomplete();
                }
            });

            textarea.addEventListener('keydown', function(e) {
                if (!autocomplete.classList.contains('active')) return;

                const items = listContainer.querySelectorAll('.mention-autocomplete-item');

                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    selectedMentionIndex = Math.min(selectedMentionIndex + 1, items.length - 1);
                    updateMentionSelection();
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    selectedMentionIndex = Math.max(selectedMentionIndex - 1, 0);
                    updateMentionSelection();
                } else if (e.key === 'Enter' || e.key === 'Tab') {
                    if (items.length > 0) {
                        e.preventDefault();
                        insertMention(items[selectedMentionIndex].dataset.mentionData);
                    }
                } else if (e.key === 'Escape') {
                    hideMentionAutocomplete();
                }
            });

            // Close on click outside
            document.addEventListener('click', function(e) {
                if (!textarea.contains(e.target) && !autocomplete.contains(e.target)) {
                    hideMentionAutocomplete();
                }
            });

            function showMentionAutocomplete() {
                // Filter data based on query
                const filtered = mentionData.filter(item => {
                    const searchStr = `${item.name} ${item.id} ${item.meta}`.toLowerCase();
                    return searchStr.includes(mentionQuery);
                });

                if (filtered.length === 0) {
                    hideMentionAutocomplete();
                    return;
                }

                listContainer.innerHTML = '';
                filtered.forEach((item, index) => {
                    const div = document.createElement('div');
                    div.className = 'mention-autocomplete-item';
                    if (index === 0) div.classList.add('selected');
                    div.dataset.mentionData = JSON.stringify(item);

                    const icon = document.createElement('div');
                    icon.className = `mention-autocomplete-icon ${item.type}`;
                    icon.innerHTML = `<i class="fas ${item.icon}"></i>`;

                    const info = document.createElement('div');
                    info.className = 'mention-autocomplete-info';

                    const name = document.createElement('div');
                    name.className = 'mention-autocomplete-name';
                    name.textContent = `${item.name} (${item.id})`;

                    const meta = document.createElement('div');
                    meta.className = 'mention-autocomplete-meta';
                    meta.textContent = item.meta;

                    info.appendChild(name);
                    info.appendChild(meta);

                    div.appendChild(icon);
                    div.appendChild(info);

                    div.addEventListener('click', function() {
                        insertMention(this.dataset.mentionData);
                    });

                    listContainer.appendChild(div);
                });

                // Position the dropdown using fixed positioning
                const textareaRect = textarea.getBoundingClientRect();
                autocomplete.style.left = textareaRect.left + 'px';
                autocomplete.style.bottom = (window.innerHeight - textareaRect.top + 8) + 'px';
                autocomplete.style.maxWidth = textareaRect.width + 'px';

                selectedMentionIndex = 0;
                autocomplete.classList.add('active');
            }

            function hideMentionAutocomplete() {
                autocomplete.classList.remove('active');
                mentionStartPos = -1;
                mentionQuery = '';
            }

            function updateMentionSelection() {
                const items = listContainer.querySelectorAll('.mention-autocomplete-item');
                items.forEach((item, index) => {
                    if (index === selectedMentionIndex) {
                        item.classList.add('selected');
                        item.scrollIntoView({ block: 'nearest' });
                    } else {
                        item.classList.remove('selected');
                    }
                });
            }

            function insertMention(dataStr) {
                const data = JSON.parse(dataStr);
                const text = textarea.value;
                const beforeMention = text.substring(0, mentionStartPos);
                const afterMention = text.substring(textarea.selectionStart);

                // Insert mention tag
                const mentionTag = `@${data.name} (${data.id})`;
                textarea.value = beforeMention + mentionTag + ' ' + afterMention;

                // Set cursor position after the mention
                const newCursorPos = beforeMention.length + mentionTag.length + 1;
                textarea.setSelectionRange(newCursorPos, newCursorPos);
                textarea.focus();

                hideMentionAutocomplete();
            }
        }

        // Consensus Builder Modal
        function showConsensusBuilder() {
            const modal = document.getElementById('consensus-builder-modal');
            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeConsensusBuilder() {
            const modal = document.getElementById('consensus-builder-modal');
            modal.classList.remove('active');
            document.body.style.overflow = '';
        }

        function selectConsensusOption(fieldName, optionValue) {
            // Remove selected class from all options in this field
            const fieldOptions = document.querySelectorAll(`[data-field="${fieldName}"]`);
            fieldOptions.forEach(opt => opt.classList.remove('selected'));

            // Add selected class to clicked option
            const selectedOption = document.querySelector(`[data-field="${fieldName}"][data-value="${optionValue}"]`);
            if (selectedOption) {
                selectedOption.classList.add('selected');
            }
        }

        function saveConsensusChanges() {
            // Simulate saving with a brief animation
            const modal = document.getElementById('consensus-builder-modal');
            const modalContent = modal.querySelector('.modal-content');

            // Flash green to indicate success
            modalContent.style.transition = 'background 0.3s';
            modalContent.style.background = '#dcfce7';

            setTimeout(() => {
                modalContent.style.background = 'white';
                setTimeout(() => {
                    closeConsensusBuilder();
                    alert('✓ Network consensus established!\n\nLead Org, PA, and TC have confirmed and synced their data.\n\n2 organizations (SS, YS) still need to review and confirm to match the agreed-upon values.');
                }, 300);
            }, 300);
        }
    </script>

